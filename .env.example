# Autodesk Platform Services (APS) — Model Derivative + Viewer
APS_CLIENT_ID=
APS_CLIENT_SECRET=

# LLM provider for the component assembly engine
LLM_API_KEY=

# Backend
PORT=8787
BACKEND_URL=http://localhost:8787

# Frontend (Next.js public vars)
NEXT_PUBLIC_BACKEND_URL=http://localhost:8787

# Spatial twin 3D model — Sketchfab embed (replaces the off-critical-path APS viewer).
# Set to the Sketchfab MODEL ID (the hash in the model URL, e.g. the part after
# /models/ in https://sketchfab.com/models/<id>). When set, the twin renders the
# live rendered-model embed and relabels the slot "Proposed building — rendered
# model + site." When empty, the twin gracefully falls back to the renderings hero
# + a "rendered 3D model — wiring up" note. NEXT_PUBLIC_ so it inlines client-side.
NEXT_PUBLIC_SKETCHFAB_MODEL_ID=
